// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  cliente
  admin
}

enum EstadoCotizacion {
  borrador
  enviada
  aceptada
  rechazada
  cancelada
}

enum EstadoProyecto {
  planificacion
  en_progreso
  pausado
  finalizado
}

enum EstadoTareaProyecto {
  pendiente
  en_progreso
  bloqueada
  completada
}

enum MonedaProducto {
  MXN
  USD
}

enum TipoCompatibilidad {
  compatible
  incompatible
}

model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(160)
  email         String     @unique @db.VarChar(160)
  passwordHash  String     @map("password_hash") @db.VarChar(255)
  telefono      String?    @db.VarChar(30)
  empresa       String?    @db.VarChar(180)
  cargo         String?    @db.VarChar(120)
  rol           RolUsuario @default(cliente)
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  cotizaciones  Cotizacion[]
  proyectos     Proyecto[]

  @@map("usuarios")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  razonSocial String   @db.VarChar(180)
  rfc         String   @unique @db.VarChar(13)
  email       String?  @unique @db.VarChar(160)
  telefono    String?  @db.VarChar(30)
  sector      String?  @db.VarChar(120)
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())
	actualizadoEn DateTime @updatedAt

	@@map("clientes")
}

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique @db.VarChar(100)
  descripcion String?    @db.VarChar(255)
  productos   Producto[]
  creadoEn    DateTime   @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("categorias")
}

model Producto {
  id                       Int                     @id @default(autoincrement())
  nombre                   String                  @db.VarChar(180)
  descripcion              String?                 @db.VarChar(500)
  fabricante               String?                 @db.VarChar(120)
  numeroParte              String?                 @map("numero_parte") @db.VarChar(100)
  skuInterno               String?                 @map("sku_interno") @unique @db.VarChar(100)
  familia                  String?                 @db.VarChar(120)
  moneda                   MonedaProducto          @default(MXN)
  especificacionesTecnicas Json?                   @map("especificaciones_tecnicas")
  precio                   Float
  stock                    Int                     @default(0)
  imagenUrl                String?                 @db.VarChar(255)
  urlDocumento             String?                 @db.VarChar(255)
  categoriaId              Int
  categoria                Categoria               @relation(fields: [categoriaId], references: [id])
  activo                   Boolean                 @default(true)
  creadoEn                 DateTime                @default(now())
  actualizadoEn            DateTime                @updatedAt
  cotizacionItems          ItemCotizacion[]
  compatibilidadesOrigen   CompatibilidadProducto[] @relation("compatibilidad_origen")
  compatibilidadesDestino  CompatibilidadProducto[] @relation("compatibilidad_destino")

  @@map("productos")
}

model CompatibilidadProducto {
  id               Int                @id @default(autoincrement())
  productoOrigenId Int                @map("producto_origen_id")
  productoDestinoId Int               @map("producto_destino_id")
  tipo             TipoCompatibilidad
  nota             String?            @db.VarChar(255)
  creadoEn         DateTime           @default(now())
  actualizadoEn    DateTime           @updatedAt
  productoOrigen   Producto           @relation("compatibilidad_origen", fields: [productoOrigenId], references: [id], onDelete: Cascade)
  productoDestino  Producto           @relation("compatibilidad_destino", fields: [productoDestinoId], references: [id], onDelete: Cascade)

  @@unique([productoOrigenId, productoDestinoId, tipo])
  @@map("producto_compatibilidades")
}

model Cotizacion {
  id              Int              @id @default(autoincrement())
  numero          String           @unique @db.VarChar(40)
  version         Int              @default(1)
  usuarioId       Int
  usuario         Usuario          @relation(fields: [usuarioId], references: [id])
  estado          EstadoCotizacion @default(borrador)
  subtotal        Float
  descuentoPct    Float            @default(0)
  margenPct       Float            @default(0)
  total           Float
  observaciones   String?          @db.VarChar(500)
  contactoNombre  String?          @db.VarChar(160)
  contactoCorreo  String?          @db.VarChar(160)
  contactoTelefono String?         @db.VarChar(30)
  contactoCargo   String?          @db.VarChar(120)
  contactoEmpresa String?          @db.VarChar(180)
  proyectoNombre  String?          @db.VarChar(180)
  fechaRequerida  DateTime?
  enviadoEn       DateTime?
  creadoEn        DateTime         @default(now())
  actualizadoEn   DateTime         @updatedAt
  items           ItemCotizacion[]

  @@map("cotizaciones")
}

model ItemCotizacion {
  id            Int       @id @default(autoincrement())
  cotizacionId  Int
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId    Int
  producto      Producto  @relation(fields: [productoId], references: [id])
  cantidad      Int
  precioUnitario Float
  subtotal      Float
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@map("cotizacion_items")
}

model Proyecto {
  id               Int                 @id @default(autoincrement())
  nombre           String              @db.VarChar(180)
  descripcion      String              @db.VarChar(500)
  cliente          String              @db.VarChar(180)
  estado           EstadoProyecto      @default(planificacion)
  porcentajeAvance Int                 @default(0)
  fechaInicio      DateTime
  fechaFinEstimada DateTime
  gerente          String?             @db.VarChar(160)
  presupuesto      Float               @default(0)
  activo           Boolean             @default(true)
  usuarioId        Int
  usuario          Usuario             @relation(fields: [usuarioId], references: [id])
  tareas           TareaProyecto[]
  bitacora         BitacoraProyecto[]
  creadoEn         DateTime            @default(now())
  actualizadoEn    DateTime            @updatedAt

  @@map("proyectos")
}

model TareaProyecto {
  id            Int                 @id @default(autoincrement())
  proyectoId    Int
  proyecto      Proyecto            @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  titulo        String              @db.VarChar(180)
  descripcion   String?             @db.VarChar(500)
  estado        EstadoTareaProyecto @default(pendiente)
  progreso      Int                 @default(0)
  orden         Int                 @default(0)
  fechaEstimada DateTime?
  fechaReal     DateTime?
  creadoEn      DateTime            @default(now())
  actualizadoEn DateTime            @updatedAt

  @@map("proyecto_tareas")
}

model BitacoraProyecto {
  id         Int      @id @default(autoincrement())
  proyectoId Int
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  nota       String   @db.VarChar(500)
  avance     Int      @default(0)
  creadoEn   DateTime @default(now())

  @@map("proyecto_bitacora")
}
