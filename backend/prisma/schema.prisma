// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  cliente
  admin
}

model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(160)
  email         String     @unique @db.VarChar(160)
  passwordHash  String     @map("password_hash") @db.VarChar(255)
  telefono      String?    @db.VarChar(30)
  empresa       String?    @db.VarChar(180)
  cargo         String?    @db.VarChar(120)
  rol           RolUsuario @default(cliente)
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  @@map("usuarios")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  razonSocial String   @db.VarChar(180)
  rfc         String   @unique @db.VarChar(13)
  email       String?  @unique @db.VarChar(160)
  telefono    String?  @db.VarChar(30)
  sector      String?  @db.VarChar(120)
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())
	actualizadoEn DateTime @updatedAt

	@@map("clientes")
}

model Categoria {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique @db.VarChar(100)
  descripcion String?    @db.VarChar(255)
  productos   Producto[]
  creadoEn    DateTime   @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("categorias")
}

model Producto {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(180)
  descripcion   String?    @db.VarChar(255)
  precio        Float
  stock         Int        @default(0)
  imagenUrl     String?    @db.VarChar(255)
  categoriaId   Int
  categoria     Categoria  @relation(fields: [categoriaId], references: [id])
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  @@map("productos")
}
